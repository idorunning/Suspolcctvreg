# Server runtime configuration. Copy to .env and fill in values for local dev.
# In production these should come from the orchestrator's secret store.

# HTTP
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# Postgres
DATABASE_URL="postgres://suspol:suspol@localhost:5432/suspolcctvreg"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_TTL_SECONDS=28800

# LDAP / Active Directory
LDAP_URL="ldaps://ad.sussex.police.uk:636"
LDAP_BIND_DN="CN=svc_cctvreg,OU=ServiceAccounts,DC=sussex,DC=police,DC=uk"
LDAP_BIND_PASSWORD="replace-me"
LDAP_SEARCH_BASE="OU=Users,DC=sussex,DC=police,DC=uk"
LDAP_SEARCH_FILTER="(|(mail={{email}})(userPrincipalName={{email}}))"
# Comma-separated list of AD group DNs; matches grant 'user' role. Everything
# else defaults to 'viewer'. Admin role is assigned via the admin panel.
LDAP_USER_GROUP_DNS=""

# Email of the first admin. On their first successful login the row is
# promoted to role='admin', status='approved' automatically.
ADMIN_BOOTSTRAP_EMAIL="nathan.tracey@sussex.police.uk"
