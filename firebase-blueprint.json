{
  "entities": {
    "Camera": {
      "title": "Camera",
      "description": "A record of an accessible CCTV or doorbell camera.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["cctv", "doorbell", "police_council", "other"],
          "description": "The type of camera."
        },
        "ownerName": {
          "type": "string",
          "description": "Name of the camera owner."
        },
        "contactNumber": {
          "type": "string",
          "description": "Contact number for the owner."
        },
        "referenceNumber": {
          "type": "string",
          "description": "Police reference number."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes about the camera."
        },
        "latitude": {
          "type": "number",
          "description": "Latitude of the camera location."
        },
        "longitude": {
          "type": "number",
          "description": "Longitude of the camera location."
        },
        "direction": {
          "type": "number",
          "description": "Direction the camera is facing in degrees (0-360)."
        },
        "fieldOfView": {
          "type": "number",
          "description": "Approximate field of view in degrees."
        },
        "addedBy": {
          "type": "string",
          "description": "User ID of the officer who added the record."
        },
        "creatorEmail": {
          "type": "string",
          "description": "Email of the officer who added the record."
        },
        "lastVerifiedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the camera was last verified as active."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the record was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the record was last updated."
        }
      },
      "required": ["type", "latitude", "longitude", "addedBy", "creatorEmail", "createdAt", "updatedAt"]
    },
    "User": {
      "title": "User",
      "description": "A police officer using the system.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address."
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user", "viewer"],
          "description": "The user's role."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user record was created."
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "EventLog": {
      "title": "EventLog",
      "description": "A record of an action taken by a user.",
      "type": "object",
      "properties": {
        "action": {
          "type": "string",
          "enum": ["login", "logout", "camera_added", "camera_amended", "camera_removed"],
          "description": "The action performed."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who performed the action."
        },
        "userEmail": {
          "type": "string",
          "description": "The email of the user who performed the action."
        },
        "details": {
          "type": "string",
          "description": "Additional details about the action."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the action occurred."
        }
      },
      "required": ["action", "userId", "userEmail", "timestamp"]
    }
  },
  "firestore": {
    "/cameras/{cameraId}": {
      "schema": {
        "$ref": "#/entities/Camera"
      },
      "description": "Stores all camera records."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles and roles."
    },
    "/events/{eventId}": {
      "schema": {
        "$ref": "#/entities/EventLog"
      },
      "description": "Stores admin event logs."
    }
  }
}
