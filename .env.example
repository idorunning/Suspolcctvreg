# Frontend build-time configuration. Copy to .env.local for local development.
# All VITE_* values are baked into the client bundle at build time.

# Same-origin API base. Nginx proxies this to the backend container.
VITE_API_BASE_URL="/api"

# Tile URL served by the tileserver-gl container (proxied via Nginx).
VITE_TILE_URL="/tiles/{z}/{x}/{y}.png"
VITE_TILE_ATTRIBUTION="© OpenStreetMap contributors"

# Optional geocoder URL (Nominatim-compatible). Leave empty to hide the
# location-search UI. When set, requests should go through a same-origin
# proxy so no external calls leave the on-prem network.
VITE_GEOCODER_URL=""

# Shown in the Auth screen for pending-account support requests.
VITE_ADMIN_CONTACT_EMAIL="cctv-admin@sussex.police.uk"
